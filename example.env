# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL=""

# ScaleKit — get these from Scalekit Dashboard → Developers → API Credentials
SCALEKIT_ENV_URL=""
SCALEKIT_CLIENT_ID=""
SCALEKIT_CLIENT_SECRET=""

# Session — generate with: openssl rand -base64 32
SESSION_SECRET=""

# App base URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ZenRows — get from https://app.zenrows.com/
ZENROWS_API_KEY=""

# OpenAI
# OPENAI_API_KEY=""

# Replace OpenAI with OpenRouter
OPENAI_API_KEY=""
# OPENAI_API_KEY=""
# This line tells your code to talk to OpenRouter instead of OpenAI
NEXT_PUBLIC_AI_BASE_URL="https://openrouter.ai/api/v1"
# Choose a free model
AI_MODEL=""

# Brevo (formerly Sendinblue) — get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
BREVO_SENDER_NAME="SupportIQ"
BREVO_SENDER_EMAIL=""
