generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum KnowledgeSourceType {
  WEB
  FILE
  TEXT
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ChatbotStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SessionStatus {
  AI_ACTIVE
  HUMAN_REQUIRED
  HUMAN_RESOLVED
}

enum MessageRole {
  user
  assistant
  human_agent
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          WorkspaceMember[]
  knowledgeSources KnowledgeSource[]
  chatbots         Chatbot[]
  sessions         ChatSession[]
  settings         WorkspaceSettings?
  apiKeys          ApiKey[]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships WorkspaceMember[]
  settings     UserSettings?
}

// Join table — one user can belong to many workspaces with different roles
model WorkspaceMember {
  id          String    @id @default(cuid())
  role        UserRole  @default(MEMBER)
  joinedAt    DateTime  @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model KnowledgeSource {
  id        String                @id @default(cuid())
  name      String
  type      KnowledgeSourceType
  status    KnowledgeSourceStatus @default(PENDING)

  // WEB: stores the URL
  // FILE: stores a storage path / object key
  // TEXT: stores raw text content
  sourceUrl String?
  filePath  String?
  content   String?

  // Metadata returned after processing (chunk count, token count, etc.)
  meta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  chatbotSources ChatbotKnowledgeSource[]
  chunks         DocumentChunk[]

  @@index([workspaceId])
  @@index([type])
}

// Vector chunks produced from a KnowledgeSource after processing.
// The embedding column uses pgvector — Prisma treats it as Unsupported.
model DocumentChunk {
  id         String   @id @default(cuid())
  content    String
  // 1536-dimension vector from text-embedding-3-small
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  createdAt  DateTime @default(now())

  knowledgeSourceId String
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)

  @@index([knowledgeSourceId])
}

model Chatbot {
  id     String        @id @default(cuid())
  name   String
  status ChatbotStatus @default(DRAFT)

  // System prompt and behaviour settings
  systemPrompt    String?
  welcomeMessage  String?

  // Visual + behaviour config stored as JSON:
  // { primaryColor, backgroundColor, fontFamily, avatarUrl,
  //   temperature, maxTokens, ... }
  config Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  knowledgeSources ChatbotKnowledgeSource[]
  sessions         ChatSession[]

  @@index([workspaceId])
  @@index([status])
}

model ChatSession {
  id        String        @id @default(cuid())
  status    SessionStatus @default(AI_ACTIVE)

  // Optional visitor identifier (e.g. anonymous fingerprint or user-provided email)
  visitorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  chatbotId String
  chatbot   Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  @@index([workspaceId])
  @@index([chatbotId])
  @@index([status])
}

model ChatMessage {
  id      String      @id @default(cuid())
  role    MessageRole
  content String

  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// Many-to-many: a chatbot can have multiple knowledge sources
model ChatbotKnowledgeSource {
  chatbotId         String
  chatbot           Chatbot         @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  knowledgeSourceId String
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)

  attachedAt DateTime @default(now())

  @@id([chatbotId, knowledgeSourceId])
  @@index([knowledgeSourceId])
}

// ─── Settings Models ───────────────────────────────────────────────────────────

enum AiProvider {
  OPENAI
  ANTHROPIC
  OPENROUTER
}

model WorkspaceSettings {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String  @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // AI Provider settings
  aiProvider    AiProvider @default(OPENROUTER)
  aiModel       String?    @default("meta-llama/llama-3.3-70b-instruct:free")
  aiApiKey      String?

  // Appearance settings
  primaryColor    String @default("#6366f1")
  backgroundColor String @default("#ffffff")
  fontFamily      String @default("inter")

  // Notification settings (JSON)
  notifications Json @default("{}")

  @@index([workspaceId])
}

model UserSettings {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile
  avatarUrl String?

  // Notification preferences
  emailNotifications   Boolean @default(true)
  pushNotifications    Boolean @default(true)
  notificationFrequency String  @default("instant")

  // Appearance
  theme String @default("system")

  @@index([userId])
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyPrefix   String
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  expiresAt DateTime?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
}
